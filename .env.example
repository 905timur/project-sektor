# Exchange API (Crypto.com) - Get these from your exchange dashboard
CRYPTO_COM_API_KEY=your_api_key_here
CRYPTO_COM_API_SECRET=your_api_secret_here

# AI Providers
# Get Anthropic API key from: https://www.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Get OpenRouter API key from: https://openrouter.ai/ (for DeepSeek - FREE)
OPENROUTER_API_KEY=your_openrouter_key_here

# Telegram Notifications - Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# SurrealDB (optional - uses embedded KV by default)
# SURREALDB_URL=surrealkv://data/surreal.db
# For standalone server:
# SURREALDB_URL=ws://localhost:8000
